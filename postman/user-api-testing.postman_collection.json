{
    "info": {
        "name": "User API Testing Collection",
        "description": "A sample Postman collection for testing login API behavior.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Login - Valid Credentials",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"\n}"
                },
                "url": {
                    "raw": "https://example.com/api/login",
                    "protocol": "https",
                    "host": [
                        "example",
                        "com"
                    ],
                    "path": [
                        "api",
                        "login"
                    ]
                }
            },
            "response": []
        },
